{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user balance and status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "balance"]
    },
    "Deposit": {
      "title": "Deposit Request",
      "description": "User deposit requests with payment proofs",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "amount": { "type": "number" },
        "screenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "screenshotUrl", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Primary user profile data"
    },
    "/deposits/{depositId}": {
      "schema": "Deposit",
      "description": "Collection of all deposit requests"
    },
    "/withdrawals/{withdrawalId}": {
      "schema": "Withdrawal",
      "description": "Collection of all withdrawal requests"
    }
  }
}
